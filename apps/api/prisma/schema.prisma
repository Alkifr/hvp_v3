generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_CLOUD_URL")
}

enum PlanningLevel {
  STRATEGIC
  OPERATIONAL
}

enum EventStatus {
  DRAFT
  PLANNED
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
  DELETED
}

enum EventPlanningKind {
  PLANNED
  UNPLANNED
}

enum EventAuditAction {
  CREATE
  UPDATE
  RESERVE
  UNRESERVE
}

enum TechnicalPlanStatus {
  DRAFT
  IN_REVIEW
  READY
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TechnicalNeedCategory {
  PERSONNEL
  MATERIAL
  TOOL
  DOCUMENTATION
  EQUIPMENT
  CONTRACTOR
  OTHER
}

enum TechnicalNeedStatus {
  NEEDED
  REQUESTED
  IN_PROGRESS
  READY
  BLOCKED
  CANCELLED
}

enum TechnicalStepStatus {
  NOT_STARTED
  READY
  IN_PROGRESS
  BLOCKED
  DONE
  SKIPPED
}

enum StockMovementType {
  IN
  OUT
  ADJUST
}

// Узкий/широкий фюзеляж — для подбора варианта расстановки под типы ВС
enum BodyType {
  NARROW_BODY   // узкий (A320, B737, …)
  WIDE_BODY     // широкий (A330, B777, …)
}

enum OptimizationScoreCategory {
  REWARD
  PENALTY
  LIMIT
}

enum OptimizationScoreUnit {
  POINTS
  POINTS_PER_HOUR
  HOURS
  BOOLEAN
  MULTIPLIER
}

enum OptimizationScoreScope {
  NEW_EVENT
  EXISTING_EVENT
  PLACEMENT
  LAYOUT
  STAND
  TOW
  PRIORITY
}

// Роль пользователя в песочнице плана
enum SandboxMemberRole {
  OWNER
  EDITOR
  VIEWER
}

model Shift {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  // минуты от полуночи (локальные)
  startMin  Int
  endMin    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planLines  EventWorkPlanLine[]
  actualLines EventWorkActualLine[]
  timeEntries TimeEntry[]

  @@index([isActive])
}

model Person {
  id        String   @id @default(uuid())
  code      String?  @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills        PersonSkill[]
  timeEntries   TimeEntry[]
  unavailability PersonUnavailability[]

  @@index([isActive])
}

model Skill {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  people     PersonSkill[]
  planLines  EventWorkPlanLine[]
  actualLines EventWorkActualLine[]
  timeEntries TimeEntry[]

  @@index([isActive])
}

model PersonSkill {
  personId  String
  skillId   String
  level     Int?
  validFrom DateTime?
  validTo   DateTime?

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([personId, skillId])
  @@index([skillId])
}

model PersonUnavailability {
  id        String   @id @default(uuid())
  personId  String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, startAt, endAt])
}

model EventWorkPlanLine {
  id            String   @id @default(uuid())
  eventId       String
  // контекст планирования: null = рабочий контур, иначе — песочница
  sandboxId     String?
  date          DateTime // начало суток (UTC) для планирования по дням
  shiftId       String
  skillId       String
  // потребность: сколько людей нужно на смену по квалификации
  plannedHeadcount Int?
  plannedMinutes Int
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event   MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shift   Shift            @relation(fields: [shiftId], references: [id])
  skill   Skill            @relation(fields: [skillId], references: [id])
  sandbox Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId, date])
  @@index([skillId])
  @@index([shiftId])
  @@index([sandboxId])
  @@unique([eventId, date, shiftId, skillId])
}

model EventWorkActualLine {
  id              String   @id @default(uuid())
  eventId         String
  sandboxId       String?
  date            DateTime // начало суток (UTC)
  shiftId         String
  skillId         String
  actualHeadcount Int
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  event   MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shift   Shift            @relation(fields: [shiftId], references: [id])
  skill   Skill            @relation(fields: [skillId], references: [id])
  sandbox Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId, date])
  @@index([skillId])
  @@index([shiftId])
  @@index([sandboxId])
  @@unique([eventId, date, shiftId, skillId])
}

model TimeEntry {
  id        String   @id @default(uuid())
  eventId   String
  sandboxId String?
  personId  String
  skillId   String
  shiftId   String?
  startAt   DateTime
  endAt     DateTime
  minutes   Int
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event   MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person  Person           @relation(fields: [personId], references: [id])
  skill   Skill            @relation(fields: [skillId], references: [id])
  shift   Shift?           @relation(fields: [shiftId], references: [id])
  sandbox Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId, startAt])
  @@index([personId, startAt])
  @@index([skillId])
  @@index([sandboxId])
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements    StockMovement[]
  reservations MaterialReservation[]
  issues       MaterialIssue[]

  @@index([isActive])
}

model Material {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  uom       String   // например "EA", "KG"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements    StockMovement[]
  reservations MaterialReservation[]
  issues       MaterialIssue[]

  @@index([isActive])
}

model StockMovement {
  id          String            @id @default(uuid())
  materialId  String
  warehouseId String
  type        StockMovementType
  qty         Float
  eventId     String?
  sandboxId   String?
  notes       String?
  createdAt   DateTime          @default(now())

  material  Material           @relation(fields: [materialId], references: [id])
  warehouse Warehouse          @relation(fields: [warehouseId], references: [id])
  event     MaintenanceEvent?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  sandbox   Sandbox?           @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([warehouseId, materialId, createdAt])
  @@index([eventId])
  @@index([sandboxId])
}

model MaterialReservation {
  id          String   @id @default(uuid())
  eventId     String
  sandboxId   String?
  materialId  String
  warehouseId String
  qtyReserved Float
  needByDate  DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  material  Material         @relation(fields: [materialId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  sandbox   Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId, needByDate])
  @@index([warehouseId, materialId])
  @@index([sandboxId])
  @@unique([eventId, materialId, warehouseId, needByDate])
}

model MaterialIssue {
  id          String   @id @default(uuid())
  eventId     String
  sandboxId   String?
  materialId  String
  warehouseId String
  qtyIssued   Float
  issuedAt    DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  material  Material         @relation(fields: [materialId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  sandbox   Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId, issuedAt])
  @@index([warehouseId, materialId])
  @@index([sandboxId])
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  displayName        String?
  passwordHash       String
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  roles UserRole[]

  ownedSandboxes     Sandbox[]       @relation("SandboxOwner")
  sandboxMemberships SandboxMember[]

  @@index([isActive])
}

// Песочница плана: именованное изолированное пространство для «игры» с планом
model Sandbox {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User            @relation("SandboxOwner", fields: [ownerId], references: [id])
  members SandboxMember[]

  events            MaintenanceEvent[]
  placements        EventPlacement[]
  reservations      StandReservation[]
  towSegments       EventTow[]
  auditTrail        MaintenanceEventAudit[]
  workPlanLines     EventWorkPlanLine[]
  workActualLines   EventWorkActualLine[]
  timeEntries       TimeEntry[]
  materialReservations MaterialReservation[]
  materialIssues    MaterialIssue[]
  stockMovements    StockMovement[]
  technicalPlans    EventTechnicalPlan[]
  technicalNeeds    EventTechnicalNeed[]
  technicalSteps    EventTechnicalStep[]

  @@index([ownerId])
}

model SandboxMember {
  sandboxId String
  userId    String
  role      SandboxMemberRole @default(EDITOR)
  addedAt   DateTime          @default(now())

  sandbox Sandbox @relation(fields: [sandboxId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sandboxId, userId])
  @@index([userId])
}

model Role {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Operator {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aircraft  Aircraft[]
  palettes  AircraftTypePalette[]
}

model AircraftType {
  id          String    @id @default(uuid())
  icaoType    String?   @unique
  name        String
  manufacturer String?
  bodyType    BodyType? // узкий/широкий фюзеляж — для подбора варианта расстановки
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  aircraft  Aircraft[]
  palettes  AircraftTypePalette[]
  hangarStandRules HangarStandAircraftType[]
  placementPriorityRules PlacementPriorityRuleAircraftType[]
}

// Палитра: цвет для связки "оператор + тип ВС"
model AircraftTypePalette {
  id             String   @id @default(uuid())
  operatorId     String
  aircraftTypeId String
  // hex, например #f59e0b
  color          String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  operator    Operator    @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  aircraftType AircraftType @relation(fields: [aircraftTypeId], references: [id], onDelete: Cascade)

  @@unique([operatorId, aircraftTypeId])
  @@index([operatorId])
  @@index([aircraftTypeId])
  @@index([isActive])
}

model Aircraft {
  id           String      @id @default(uuid())
  tailNumber   String      @unique
  serialNumber String?
  operatorId   String
  typeId       String
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  operator Operator    @relation(fields: [operatorId], references: [id])
  type     AircraftType @relation(fields: [typeId], references: [id])

  events MaintenanceEvent[]

  @@index([operatorId])
  @@index([typeId])
}

model EventType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  color     String?  // hex, например #3b82f6
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events MaintenanceEvent[]
  placementPriorityRules PlacementPriorityRuleEventType[]
}

model Hangar {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  layouts HangarLayout[]
  events  MaintenanceEvent[]
  placements EventPlacement[]
  placementPriorityRules PlacementPriorityRule[]
}

model HangarLayout {
  id          String   @id @default(uuid())
  hangarId    String
  code        String
  name        String
  description String?
  // Геометрия площади (для базовой визуализации)
  widthMeters  Float?
  heightMeters Float?
  // Препятствия на плане: массив { type: "rect", x, y, w, h } в метрах (колонны, стены и т.д.)
  obstacles    Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hangar Hangar @relation(fields: [hangarId], references: [id])
  stands HangarStand[]

  reservations StandReservation[]
  events       MaintenanceEvent[]
  placements  EventPlacement[]
  placementPriorityRules PlacementPriorityRule[]

  @@unique([hangarId, code])
  @@index([hangarId])
}

model HangarStand {
  id        String    @id @default(uuid())
  layoutId  String
  code      String
  name      String
  // Deprecated: совместимость теперь задаётся через HangarStandAircraftType.
  bodyType  BodyType?

  // Прямоугольник места в координатах "метры" (простой SVG план)
  x      Float
  y      Float
  w      Float
  h      Float
  rotate Float @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  layout HangarLayout @relation(fields: [layoutId], references: [id])
  allowedAircraftTypes HangarStandAircraftType[]
  reservations StandReservation[]
  placements EventPlacement[]
  placementPriorityRules PlacementPriorityRule[]

  @@unique([layoutId, code])
  @@index([layoutId])
}

model HangarStandAircraftType {
  standId        String
  aircraftTypeId String
  createdAt      DateTime @default(now())

  stand        HangarStand  @relation(fields: [standId], references: [id], onDelete: Cascade)
  aircraftType AircraftType @relation(fields: [aircraftTypeId], references: [id], onDelete: Cascade)

  @@id([standId, aircraftTypeId])
  @@index([aircraftTypeId])
}

model PlacementPriorityRule {
  id            String   @id @default(uuid())
  hangarId      String
  layoutId      String
  standId       String
  priorityScore Int      @default(500)
  sourceEventName String?
  sourceAircraftTypeText String?
  conditionText String?
  comment       String?
  source        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hangar Hangar       @relation(fields: [hangarId], references: [id])
  layout HangarLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  stand  HangarStand  @relation(fields: [standId], references: [id], onDelete: Cascade)

  eventTypes    PlacementPriorityRuleEventType[]
  aircraftTypes PlacementPriorityRuleAircraftType[]

  @@index([hangarId])
  @@index([layoutId])
  @@index([standId])
  @@index([isActive])
}

model PlacementPriorityRuleEventType {
  ruleId      String
  eventTypeId String
  createdAt   DateTime @default(now())

  rule      PlacementPriorityRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  eventType EventType             @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@id([ruleId, eventTypeId])
  @@index([eventTypeId])
}

model PlacementPriorityRuleAircraftType {
  ruleId         String
  aircraftTypeId String
  createdAt      DateTime @default(now())

  rule         PlacementPriorityRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  aircraftType AircraftType          @relation(fields: [aircraftTypeId], references: [id], onDelete: Cascade)

  @@id([ruleId, aircraftTypeId])
  @@index([aircraftTypeId])
}

model OptimizationProfile {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules OptimizationScoreRule[]

  @@index([isActive])
  @@index([isDefault])
}

model OptimizationScoreRule {
  id        String                    @id @default(uuid())
  profileId String
  code      String
  name      String
  category  OptimizationScoreCategory
  scope     OptimizationScoreScope
  value     Float
  unit      OptimizationScoreUnit
  isActive  Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  profile OptimizationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, code])
  @@index([profileId])
  @@index([category])
  @@index([scope])
  @@index([isActive])
}

model MaintenanceEvent {
  id            String        @id @default(uuid())
  level         PlanningLevel
  status        EventStatus   @default(PLANNED)
  planningKind  EventPlanningKind @default(PLANNED)
  title         String

  // контекст планирования: null = рабочий контур, иначе — песочница
  sandboxId     String?

  aircraftId    String?       // null при виртуальном борте (массовое планирование)
  eventTypeId   String

  // Виртуальный борт: заполняется при массовом планировании; при закрытии события создаётся Aircraft и сюда записывается aircraftId
  virtualAircraft Json?      // { operatorId, aircraftTypeId, label }

  startAt       DateTime
  endAt         DateTime
  budgetStartAt DateTime?
  budgetEndAt   DateTime?
  actualStartAt DateTime?
  actualEndAt   DateTime?

  // Опционально можно заранее закрепить в ангаре/варианте (даже без конкретного места)
  hangarId      String?
  layoutId      String?

  notes         String?

  // Lineage: связь копии с источником (для merge/dedup между песочницами)
  // originEventId — корень в рабочем контуре (null = событие создано с нуля или само является корнем в prod)
  // sourceEventId — непосредственный родитель при копировании
  // sourceSandboxId — песочница-источник (null = скопировано из рабочего контура)
  originEventId   String?
  sourceEventId   String?
  sourceSandboxId String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  aircraft  Aircraft? @relation(fields: [aircraftId], references: [id])
  eventType EventType @relation(fields: [eventTypeId], references: [id])

  hangar  Hangar?       @relation(fields: [hangarId], references: [id])
  layout  HangarLayout? @relation(fields: [layoutId], references: [id])
  sandbox Sandbox?      @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  reservations StandReservation[]
  placements   EventPlacement[]
  auditTrail  MaintenanceEventAudit[]
  towSegments EventTow[]

  workPlanLines        EventWorkPlanLine[]
  workActualLines      EventWorkActualLine[]
  timeEntries          TimeEntry[]
  materialReservations MaterialReservation[]
  materialIssues       MaterialIssue[]
  stockMovements       StockMovement[]
  technicalPlan        EventTechnicalPlan?

  @@index([aircraftId])
  @@index([eventTypeId])
  @@index([startAt, endAt])
  @@index([planningKind])
  @@index([hangarId])
  @@index([layoutId])
  @@index([sandboxId])
  @@index([originEventId, sandboxId])
  @@index([sourceEventId])
}

model EventTechnicalPlan {
  id           String              @id @default(uuid())
  eventId      String              @unique
  sandboxId    String?
  status       TechnicalPlanStatus @default(DRAFT)
  leadEngineer String?
  readinessPct Int                 @default(0)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  event   MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sandbox Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  needs EventTechnicalNeed[]
  steps EventTechnicalStep[]

  @@index([sandboxId])
  @@index([status])
}

model EventTechnicalNeed {
  id          String                @id @default(uuid())
  planId      String
  sandboxId   String?
  category    TechnicalNeedCategory
  description String
  quantity    String?
  requiredAt  DateTime?
  responsible String?
  status      TechnicalNeedStatus   @default(NEEDED)
  isBlocker   Boolean               @default(false)
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  plan    EventTechnicalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  sandbox Sandbox?           @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([sandboxId])
  @@index([status])
  @@index([category])
}

model EventTechnicalStep {
  id             String              @id @default(uuid())
  planId         String
  sandboxId      String?
  seq            Int                 @default(0)
  title          String
  description    String?
  responsible    String?
  plannedStartAt DateTime?
  plannedEndAt   DateTime?
  actualStartAt  DateTime?
  actualEndAt    DateTime?
  status         TechnicalStepStatus @default(NOT_STARTED)
  progressPct    Int                 @default(0)
  isBlocker      Boolean             @default(false)
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  plan    EventTechnicalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  sandbox Sandbox?           @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  predecessors EventTechnicalStepDependency[] @relation("StepDependencySuccessor")
  successors   EventTechnicalStepDependency[] @relation("StepDependencyPredecessor")

  @@index([planId, seq])
  @@index([sandboxId])
  @@index([status])
}

model EventTechnicalStepDependency {
  predecessorStepId String
  successorStepId   String

  predecessor EventTechnicalStep @relation("StepDependencyPredecessor", fields: [predecessorStepId], references: [id], onDelete: Cascade)
  successor   EventTechnicalStep @relation("StepDependencySuccessor", fields: [successorStepId], references: [id], onDelete: Cascade)

  @@id([predecessorStepId, successorStepId])
  @@index([successorStepId])
}

// Этапы размещения одного события по ангарам/местам.
// Один MaintenanceEvent остаётся логическим событием, а placements описывают,
// где и когда выполнялась работа при перебуксировках между ангарами.
model EventPlacement {
  id        String   @id @default(uuid())
  eventId   String
  sandboxId String?
  startAt   DateTime
  endAt     DateTime
  budgetStartAt DateTime?
  budgetEndAt   DateTime?
  actualStartAt DateTime?
  actualEndAt   DateTime?
  hangarId  String?
  layoutId  String?
  standId   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event   MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sandbox Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)
  hangar  Hangar?          @relation(fields: [hangarId], references: [id])
  layout  HangarLayout?    @relation(fields: [layoutId], references: [id])
  stand   HangarStand?     @relation(fields: [standId], references: [id])

  reservation StandReservation?

  @@index([eventId, sortOrder])
  @@index([sandboxId])
  @@index([hangarId])
  @@index([layoutId])
  @@index([standId, startAt, endAt])
}

// Буксировки (закатка/выкатка) как интервалы внутри события (могут быть несколько раз)
model EventTow {
  id        String   @id @default(uuid())
  eventId   String
  sandboxId String?
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event   MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sandbox Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId, startAt])
  @@index([sandboxId])
}

model MaintenanceEventAudit {
  id        String           @id @default(uuid())
  eventId   String
  sandboxId String?
  action    EventAuditAction
  actor     String           @default("browser")
  reason    String?
  // хранит diff вида { field: { from: any, to: any } }
  changes   Json?
  createdAt DateTime         @default(now())

  event   MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sandbox Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([sandboxId])
}

model StandReservation {
  id        String   @id @default(uuid())

  // Резервирование привязано к событию и, для многоангарных событий, к конкретному этапу.
  eventId     String
  placementId String? @unique
  sandboxId   String?
  layoutId    String
  standId     String

  // Диапазон резерва (может совпадать с event.startAt/endAt или отличаться)
  startAt   DateTime
  endAt     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     MaintenanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  placement EventPlacement?  @relation(fields: [placementId], references: [id], onDelete: Cascade)
  layout    HangarLayout     @relation(fields: [layoutId], references: [id])
  stand     HangarStand      @relation(fields: [standId], references: [id])
  sandbox   Sandbox?         @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([layoutId])
  @@index([standId, startAt, endAt])
  @@index([sandboxId])
}

